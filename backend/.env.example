# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required: Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: protect upload/ask endpoints with a static API key.
# Leave unset (or empty) to disable auth entirely.
API_KEY=

# Optional: max PDF upload size in MB (default: 20)
MAX_UPLOAD_MB=20
